.flex-row {
    display: flex;
    flex-direction: row;
    gap: 15dp;
}

.flex-column {
    display: flex;
    flex-direction: column;
    gap: 15dp;
}

.ten-gap {
    gap: 10dp;
}

.half-gap {
    gap: 7dp;
}

.quarter-gap {
    gap: 4dp;
}

.space-between {
    justify-content: space-between;
}

.center-items {
    align-items: center;
}

.bottom-items {
    align-items: flex-end;
}

.third-width {
    width: 30%;
}

.inner-no-margins * {
    margin: 0;
}