.flex-row {
    display: flex;
    flex-direction: row;
    gap: 15dp;
}

.flex-column {
    display: flex;
    flex-direction: column;
    gap: 15dp;
}

.half-gap {
    gap: 7dp;
}

.space-between {
    justify-content: space-between;
}

.center-items {
    align-items: center;
}

.third-width {
    width: 30%;
}