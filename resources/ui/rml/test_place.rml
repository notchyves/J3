<rml>
<head>
    <title>J3 - test place</title>
    <link type="text/rcss" href="../css/default.rcss"/>
    <link type="text/rcss" href="../css/common.rcss"/>
</head>

<body data-model="test_place_data">
    <h1>Header 1</h1>
    <h2>Header 2</h2>
    <h3>Header 3</h3>

    <p>Regular text <i>Subtext </i> <em>Less important text</em></p>

    <div class="flex-row">
        <button>Regular button</button>
        <button class="less">Less important</button>
        <button disabled>Disabled button</button>
        <button class="progress">
            <div/>
            With progress
        </button>
    </div>

    <div class="flex-row">
        <div class="flex-column half-gap">
            <label>Text field</label>
            <input type="text"/>
        </div>

        <div class="flex-column half-gap">
            <label>With text</label>
            <input type="text" value="This text field has text"/>
        </div>

        <div class="flex-column half-gap">
            <label>Disabled text field</label>
            <input disabled type="text" value="No input allowed"/>
        </div>
    </div>

    <div class="flex-row">
        <div class="flex-column">
            <div class="flex-column half-gap">
                <label>Slider</label>
                <input type="range" min="0" max="100" step="1" value="50" orientation="horizontal"/>
            </div>

            <div class="flex-column half-gap">
                <label>Disabled slider</label>
                <input disabled type="range" min="0" max="100" step="1" value="50" orientation="horizontal"/>
            </div>
        </div>

        <div class="flex-column">
            <div class="flex-column">
                <div class="flex-row half-gap">
                    <input type="checkbox" id="check1"/>
                    <label for="check1">Checkbox</label>
                </div>

                <div class="flex-row half-gap">
                    <input type="checkbox" id="check2" checked/>
                    <label for="check2">Toggled checkbox</label>
                </div>
            </div>

            <div class="drop-down">
                <div class="drop-down-selected flex-row space-between" data-event-click="drop_down_open = !drop_down_open">
                    <i data-if="drop_down_selected_items.size == 0">{{drop_down_name}}</i>
                    <p data-if="drop_down_selected_items.size > 0">{{drop_down_selected_items_formatted}}</p>

                    <img src="../../textures/arrow_down.png" width="20" height="20"/>
                </div>
                
                <div class="drop-down-items flex-column half-gap" data-attr-open="drop_down_open">
                    <div class="flex-row half-gap" data-for="item : drop_down_items">
                        <input type="checkbox" id="get_item_id(item)" data-if="drop_down_multiselect" data-event-change="drop_down_toggle(item)"/>
                        <input type="radio" id="get_item_id(item)" data-if="!drop_down_multiselect" data-event-change="drop_down_toggle(item)"/>
                        
                        <label for="get_item_id(item)">{{item}}</label>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="color-picker flex-column half-gap">
            <label>Color picker</label>
            
            <div class="flex-row half-gap">
                <button class="color-picker-button" data-event-click="color_picker_open = !color_picker_open" data-style-background-color="'hsla(' + color_picker_color.hue + ', ' + color_picker_color.saturation + '%, ' + color_picker_color.lightness + '%, ' + color_picker_color.alpha + ')'"></button>
                
                <div class="color-picker-popover flex-column half-gap" data-attr-open="color_picker_open">
                    <div class="color-picker-zone" id="color-picker-zone"
                         data-style-decorator="'linear-gradient(to bottom, transparent, black), linear-gradient(to right, white, hsl(' + color_picker_color.hue + ', 100%, 50%))'">
                        <handle id="color-picker-marker" move_target="#self" edge_margin="-50%" data-event-drag="color_picker_update"/>
                    </div>

                    <input id="hue-slider" type="range" min="0" max="360" step="1" value="0" orientation="horizontal" data-value="color_picker_color.hue" data-event-change="color_picker_update"/>
                    <input id="alpha-slider" type="range" min="0" max="1" step="0.01" value="1" orientation="horizontal" data-value="color_picker_color.alpha" data-event-change="color_picker_update"/>

                    <input type="text" value="#FF0000" data-value="color_picker_hex" data-event-change="color_picker_update"/>
                </div>
            </div>
        </div>
    </div>
</body>
</rml>